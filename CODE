from ultralytics import YOLO
import cv2
import numpy as np
from google.colab import files
from google.colab.patches import cv2_imshow

model = YOLO("yolov8n.pt")

  from google.colab import files

uploaded = files.upload()

  video_path = "uhd_30fps.mp4"

cap = cv2.VideoCapture(video_path)

# Get video width and height
frame_width = int(cap.get(3))
frame_height = int(cap.get(4))

# Save output video
fourcc = cv2.VideoWriter_fourcc(*'mp4v')

out = cv2.VideoWriter(
    'output.mp4',
    fourcc,
    20.0,
    (frame_width, frame_height)
)

# Counting line position
line_y = 300

# Counters
entries = 0
exits = 0

# Track previous positions
person_positions = {}

frame_count = 0

while True:

    ret, frame = cap.read()

    if not ret:
        break

    # YOLO tracking
    results = model.track(frame, persist=True)

    # Draw counting line
    cv2.line(frame,
             (0, line_y),
             (frame.shape[1], line_y),
             (0, 0, 255),
             3)

    for result in results:

        boxes = result.boxes

        # Make sure tracking IDs exist
        if boxes.id is not None:

            ids = boxes.id.int().cpu().tolist()

            for box, track_id in zip(boxes, ids):

                cls = int(box.cls[0])

                # Person class only
                if cls == 0:

                    x1, y1, x2, y2 = map(int, box.xyxy[0])

                    # Draw rectangle
                    cv2.rectangle(frame,
                                  (x1, y1),
                                  (x2, y2),
                                  (0, 255, 0),
                                  2)

                    # Display tracking ID
                    cv2.putText(frame,
                                f"ID {track_id}",
                                (x1, y1 - 10),
                                cv2.FONT_HERSHEY_SIMPLEX,
                                0.5,
                                (0, 255, 0),
                                2)

                    # Center point
                    center_y = (y1 + y2) // 2

                    # Check if already tracked
                    if track_id in person_positions:

                        previous_y = person_positions[track_id]

                        # Crossing downward = entry
                        if previous_y < line_y and center_y >= line_y:
                            entries += 1

                        # Crossing upward = exit
                        elif previous_y > line_y and center_y <= line_y:
                            exits += 1

                    # Update position
                    person_positions[track_id] = center_y

    # Calculate occupancy
    occupancy = entries - exits

    # Display counters
    cv2.putText(frame,
                f"Entries: {entries}",
                (20, 40),
                cv2.FONT_HERSHEY_SIMPLEX,
                1,
                (0, 255, 0),
                2)

    cv2.putText(frame,
                f"Exits: {exits}",
                (20, 80),
                cv2.FONT_HERSHEY_SIMPLEX,
                1,
                (0, 0, 255),
                2)

    cv2.putText(frame,
                f"Occupancy: {occupancy}",
                (20, 120),
                cv2.FONT_HERSHEY_SIMPLEX,
                1,
                (255, 255, 0),
                2)

   # Save frame
out.write(frame)

frame_count += 1

if frame_count % 30 == 0:
    print(f"Processed {frame_count} frames")
    cv2_imshow(frame)

# Release everything
cap.release()
out.release()

print("Processing complete.")


